{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hoardbook",
  "version": "0.1.0",
  "identifier": "net.hoardbook",
  "build": {
    "frontendDist": "ui/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "appimage", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/512x512.png",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hoardbook",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERCRjkwMjE4M0UzN0NGN0QKUldSOXp6WStHQUw1Mi9oZzNYMzlzSGpuRjdVbWlNSS9RTTZZTjduak1QOWdZdVlqY2ErZWFOMkQK",
      "endpoints": [
        "https://github.com/Arsinine/Hoardbook/releases/latest/download/latest.json"
      ]
    }
  }
}
